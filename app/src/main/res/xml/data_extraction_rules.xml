<?xml version="1.0" encoding="utf-8"?><!--
  백업·기기이전 규칙 (API 31+). 학습 기록·설정은 보존하고, 다시 받을 수 있는
  대용량 TTS 모델(files/tts)은 클라우드 백업·기기 이전 모두에서 제외한다.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="tts" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="tts" />
    </device-transfer>
</data-extraction-rules>
