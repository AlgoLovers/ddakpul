<?xml version="1.0" encoding="utf-8"?><!--
  자동 백업 규칙 (API 30 이하 기기용 — 31+는 data_extraction_rules.xml).
  학습 기록(Room DB)·설정(SharedPreferences)은 백업하고, 다시 받을 수 있는 대용량
  TTS 모델(files/tts, 최대 ~95MB)은 제외한다 — 자동 백업 한도(25MB) 초과 방지.
-->
<full-backup-content>
    <exclude domain="file" path="tts" />
    <exclude domain="file" path="videos" />
</full-backup-content>
