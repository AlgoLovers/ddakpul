<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- 라이트 창 테마 — Compose가 그리기 전 잠깐 보이는 창 배경을 앱 캔버스 색과 맞춘다.
         forceDarkAllowed=false: 앱이 다크 테마를 직접 처리하므로 제조사 강제 다크(색 반전) 차단. -->
    <style name="Theme.DdakPul" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">#F6F7F9</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>
</resources>
